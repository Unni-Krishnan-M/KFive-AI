# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database URLs
MONGODB_URI=mongodb://localhost:27017/nexus_ai
REDIS_URL=redis://localhost:6379
CHROMA_URL=http://localhost:8000

# JWT Secrets (Change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3
OLLAMA_CODE_MODEL=deepseek-coder
OLLAMA_VISION_MODEL=llava
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_SPEECH_MODEL=whisper

# File Upload Configuration
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,docx,pptx,txt,md,jpg,jpeg,png,gif

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# AI Configuration
MAX_CONTEXT_LENGTH=4096
MAX_TOKENS_PER_REQUEST=2048
AI_TIMEOUT_MS=30000

# Memory Configuration
MEMORY_RETENTION_DAYS=365
MAX_CONVERSATIONS_PER_USER=1000

# Queue Configuration
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=5