# API Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# App Configuration
VITE_APP_NAME="KFive AI"
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Futuristic AI-powered workspace and assistant

# Feature Flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_MOBILE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false

# AI Configuration
VITE_MAX_FILE_SIZE=50MB
VITE_SUPPORTED_FILE_TYPES=pdf,docx,pptx,txt,md,jpg,jpeg,png,gif

# UI Configuration
VITE_DEFAULT_THEME=dark
VITE_ENABLE_ANIMATIONS=true
VITE_ENABLE_SOUND_EFFECTS=false

# Development
VITE_DEBUG_MODE=true
VITE_MOCK_API=false